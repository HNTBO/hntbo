---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const resource = await getEntry('resources', 'brief-generator-videoexplainer');
if (!resource) {
  throw new Error('Missing brief-generator-videoexplainer resource');
}
const { Content } = await resource.render();
---

<BaseLayout title={resource.data.title} description={resource.data.description}>
  <article class="pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="container max-w-5xl">
      <a href="/posts/briefs-personnalises-ia-skills" class="inline-flex items-center text-text-secondary hover:text-accent transition-colors mb-8">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to the article
      </a>

      <div class="rounded-2xl border border-border bg-surface/80 p-6 md:p-8 mb-10">
        <p class="text-sm uppercase tracking-[0.2em] text-accent mb-3">Agent Skill</p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary mb-4">
          {resource.data.title}
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed max-w-3xl mb-6">
          {resource.data.description}
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/downloads/brief-generator-videoexplainer.skill.md" class="btn btn-primary" download>
            Download the raw skill
          </a>
          <a href="/posts/briefs-personnalises-ia-skills" class="btn btn-secondary">
            Read the case study
          </a>
        </div>
      </div>

      <div class="prose skill-prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .skill-prose :global(pre) {
    max-height: 34rem;
  }
</style>
