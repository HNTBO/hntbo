---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const allTags = [...new Set(sortedPosts.flatMap((item) => item.data.tags || []))];
---

<BaseLayout title="Posts" description="Long-form notes on AI, creative workflows, pedagogy, and staying useful as a creative professional.">
  <section class="pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="container">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary mb-4">
        Posts
      </h1>
      <p class="text-text-secondary text-lg max-w-2xl mb-8">
        Longer notes on AI, creative workflows, pedagogy, and the work of not becoming obsolete too quickly.
      </p>

      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          <span class="tag">All posts</span>
          {allTags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <Card
            title={post.data.title}
            href={`/posts/${post.slug}`}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
